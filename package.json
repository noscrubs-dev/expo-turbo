{
  "name": "expo-turbo",
  "version": "0.1.0",
  "description": "Public TypeScript scaffold for Expo Turbo",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run lint && bun run typecheck && bun test && bun run pack:check",
    "format": "biome check --write src package.json tsconfig.json tsconfig.build.json biome.json",
    "lint": "biome check src package.json tsconfig.json tsconfig.build.json biome.json",
    "pack:check": "bun pm pack --dry-run",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noscrubs-dev/expo-turbo.git"
  },
  "bugs": {
    "url": "https://github.com/noscrubs-dev/expo-turbo/issues"
  },
  "homepage": "https://github.com/noscrubs-dev/expo-turbo#readme",
  "keywords": [
    "action-cable",
    "expo",
    "hotwire",
    "react-native",
    "rails",
    "turbo"
  ],
  "author": "NoScrubs",
  "license": "MIT",
  "engines": {
    "node": ">=20.12"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
