{
  "name": "expo-turbo",
  "version": "0.1.0",
  "description": "Native XML protocol runtime foundation for Expo and Rails",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js",
      "default": "./dist/registry/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run lint && bun run typecheck && bun run test && bun run pack:check",
    "example:expo:check": "cd example/expo && bun run check",
    "example:rails:check": "cd example/rails && bundle exec standardrb && bundle exec rspec",
    "examples:check": "bun run example:expo:check && bun run example:rails:check",
    "format": "biome check --write src package.json tsconfig.json tsconfig.build.json biome.json",
    "lint": "biome check src package.json tsconfig.json tsconfig.build.json biome.json",
    "pack:check": "bun pm pack --dry-run",
    "prepack": "bun run build",
    "test": "bun test --path-ignore-patterns=example",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noscrubs-dev/expo-turbo.git"
  },
  "bugs": {
    "url": "https://github.com/noscrubs-dev/expo-turbo/issues"
  },
  "homepage": "https://github.com/noscrubs-dev/expo-turbo#readme",
  "keywords": [
    "action-cable",
    "expo",
    "hotwire",
    "react-native",
    "rails",
    "turbo"
  ],
  "author": "NoScrubs",
  "license": "MIT",
  "engines": {
    "node": ">=20.12"
  },
  "packageManager": "bun@1.3.14",
  "peerDependencies": {
    "react": ">=19.1.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "0.9.10",
    "css-select": "7.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "fast-xml-parser": "5.10.1",
    "typescript": "^7.0.2"
  }
}
