{
  "name": "expo-turbo-example",
  "main": "expo-router/entry",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "expo": "~57.0.8",
    "expo-constants": "57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-router": "~57.0.8",
    "expo-status-bar": "~57.0.1",
    "expo-turbo": "file:../..",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-web": "~0.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node scripts/link-react-peer.mjs",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "bun test --isolate",
    "export:android": "expo export --platform android",
    "export:ios": "expo export --platform ios",
    "export:web": "expo export --platform web",
    "export:all": "bun run export:web && bun run export:ios && bun run export:android",
    "check": "bun run lint && bun run typecheck && bun run test && bun run export:all"
  }
}
