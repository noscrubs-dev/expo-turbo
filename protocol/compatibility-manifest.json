  "behaviorFixtures": [
    {
      "id": "stream-ordered-isolation",
      "kind": "stream-mutation",
      "documentFile": "fixtures/stream-behavior-ordered-document.xml",
      "streamFile": "fixtures/stream-behavior-ordered-streams.xml",
      "expectedDocumentFile": "fixtures/stream-behavior-ordered-expected.xml",
      "expectedReports": [
        {"action": "append", "status": "applied", "matchedTargets": 1, "appliedTargets": 1},
        {"action": "unknown", "status": "error", "matchedTargets": 0, "appliedTargets": 0},
        {"action": "before", "status": "applied", "matchedTargets": 1, "appliedTargets": 1},
        {"action": "after", "status": "applied", "matchedTargets": 1, "appliedTargets": 1},
        {"action": "update", "status": "applied", "matchedTargets": 1, "appliedTargets": 1},
        {"action": "remove", "status": "applied", "matchedTargets": 1, "appliedTargets": 1},
        {"action": "append", "status": "applied", "matchedTargets": 1, "appliedTargets": 1}
      ],
      "provenance": {"kind": "upstream-derived", "baseline": "turbo-8.0.23"}
    },
